{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pigeon",
  "version": "0.1.0",
  "identifier": "com.k1n1.pigeon",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pigeon - API Tester",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0RkRGOUNDOTkxNzUxQkMKUldTOFVSZVp6UG45ZEUySVZIaWdoMG56TmZXRjZSaklWQzM4UVhETk9Hb3k3Q2JrK1VJRlIyVDAK",
      "endpoints": [
        "https://github.com/pigeon-client/pigeon-client.github.io/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
